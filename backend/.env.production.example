# Production environment template for Render
# Copy values into Render Dashboard → Environment

APP_ENV=production
DEBUG=false
CREW_VERBOSE=false
CREW_MEMORY=false

# API keys (required for full pipeline)
OPENROUTER_API_KEY=
TAVILY_API_KEY=

# Optional future provider
FMP_API_KEY=

# Supabase (required for persistent report storage on Render)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# CORS – your Vercel frontend URL (no trailing slash)
# Example: https://investiq.vercel.app,http://localhost:5173
CORS_ORIGINS=https://your-app.vercel.app

# Storage
STORAGE_ENABLED=true
CHROMA_ENABLED=false

# Logging
LOG_LEVEL=INFO

# OpenRouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4.1-mini
GUARDRAIL_MAX_ANALYSIS_RETRIES=1
YFINANCE_ENABLED=true
