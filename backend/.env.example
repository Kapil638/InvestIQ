# Application
APP_NAME=InvestIQ
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# LLM – OpenRouter (unified provider)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.2
# Optional: comma-separated or JSON array override
# LLM_FALLBACK_MODELS=openai/gpt-4.1-mini,openai/gpt-4.1,anthropic/claude-3.7-sonnet
LLM_RETRY_BACKOFF_SECONDS=3,8

# CORS (add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Guardrails
GUARDRAIL_COLLECTION_MAX_AGE_HOURS=24
GUARDRAIL_STATEMENT_MAX_AGE_MONTHS=18
GUARDRAIL_NEWS_MAX_AGE_DAYS=30
GUARDRAIL_MAX_ANALYSIS_RETRIES=1
GUARDRAIL_BLOCK_ON_WARNINGS=false

# Financial Data – Yahoo Finance fundamentals; optional Tapetide MCP and Kite MCP
YFINANCE_ENABLED=true

# Tapetide MCP – read-only Indian exchange data (npx -y tapetide-mcp or remote)
TAPETIDE_MCP_ENABLED=false
TAPETIDE_MCP_URL=http://localhost:3000/mcp
TAPETIDE_API_TOKEN=<PASTE_TAPETIDE_TOKEN_HERE>
TAPETIDE_MCP_READ_ONLY=true
TAPETIDE_MCP_TIMEOUT_SECONDS=20

# Deprecated – kept for backward compatibility only (not used as primary)
NSE_BSE_MCP_ENABLED=false
NSE_BSE_MCP_URL=http://localhost:3000/mcp
NSE_BSE_MCP_READ_ONLY=true
NSE_BSE_MCP_TIMEOUT_SECONDS=20

# Kite MCP – read-only market data & portfolio (no order placement via InvestIQ)
KITE_MCP_ENABLED=true
KITE_MCP_URL=https://mcp.kite.trade/mcp
KITE_MCP_READ_ONLY=true
KITE_EXCLUDED_TOOLS=place_order,modify_order,cancel_order,place_gtt_order,modify_gtt_order,delete_gtt_order
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:8002/api/v1/kite/callback
KITE_FRONTEND_REDIRECT_URL=http://localhost:5173/portfolio

# Optional future provider
FMP_API_KEY=

# Search
TAVILY_API_KEY=

# Database & storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
CHROMA_ENABLED=true
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=research_reports
STORAGE_ENABLED=true

# Logging & cache
LOG_LEVEL=INFO
# Set true to enable in-process TTL cache (search 10m, financial/history/chat 5m, status/report/holdings 60s)
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# CrewAI
CREW_VERBOSE=false
CREW_MEMORY=false

# Limits
MAX_NEWS_RESULTS=10
MAX_DOCUMENT_CHUNKS=20
MAX_SEARCH_RESULTS=10

# Google Drive API – save report PDFs to a shared folder (service account)
# 1. Create a GCP service account with Drive API enabled
# 2. Share your target Drive folder with the service account email (Editor)
# 3. Set GOOGLE_DRIVE_ROOT_FOLDER_ID to that folder's ID (optional; defaults to Drive root)
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
# Or paste the full JSON key inline (useful on Render; do not commit real keys)
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
