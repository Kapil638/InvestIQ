# Application
APP_NAME=InvestIQ
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# LLM – OpenRouter (unified provider)
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.2
# Optional: comma-separated or JSON array override
# LLM_FALLBACK_MODELS=openai/gpt-4.1-mini,openai/gpt-4.1,anthropic/claude-3.7-sonnet
LLM_RETRY_BACKOFF_SECONDS=3,8

# CORS (add your Vercel URL in production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Guardrails
GUARDRAIL_COLLECTION_MAX_AGE_HOURS=24
GUARDRAIL_STATEMENT_MAX_AGE_MONTHS=18
GUARDRAIL_NEWS_MAX_AGE_DAYS=30
GUARDRAIL_MAX_ANALYSIS_RETRIES=1
GUARDRAIL_BLOCK_ON_WARNINGS=false

# Financial Data – Yahoo Finance fundamentals; optional Tapetide MCP and Kite MCP
YFINANCE_ENABLED=true

# Tapetide MCP – read-only Indian exchange data (npx -y tapetide-mcp or remote)
TAPETIDE_MCP_ENABLED=false
TAPETIDE_MCP_URL=http://localhost:3000/mcp
TAPETIDE_API_TOKEN=<PASTE_TAPETIDE_TOKEN_HERE>
TAPETIDE_MCP_READ_ONLY=true
TAPETIDE_MCP_TIMEOUT_SECONDS=20

# Google Drive – OAuth user delegation (required for personal Gmail accounts;
# service accounts have no storage quota of their own). Create a "Web application"
# OAuth Client ID in Google Cloud Console (APIs & Services > Credentials), add the
# redirect URI below to its "Authorized redirect URIs", and enable the Drive API.
GOOGLE_DRIVE_ENABLED=true
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URL=http://127.0.0.1:8002/api/v1/google-drive/callback
GOOGLE_DRIVE_OAUTH_FRONTEND_REDIRECT_URL=http://localhost:5173/reports
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Service-account path – only usable with a Google Workspace Shared Drive; leave
# unset on a personal Gmail account.
GOOGLE_DRIVE_SERVICE_ACCOUNT_FILE=
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON=

# Owner authentication gate – single-owner allowlist (comma-separated emails).
# Self-disabling: leave blank and every route stays open exactly as before this
# feature existed. Set it to actually turn the gate on.
ALLOWED_OWNER_EMAILS=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=
SESSION_MAX_AGE_DAYS=30

# Google Sign-In (owner login) – a SEPARATE OAuth Client ID from
# GOOGLE_DRIVE_OAUTH_CLIENT_ID above. Sign-In uses Google Identity Services
# (ID-token flow, "Authorized JavaScript origins", no redirect URI needed) —
# create a new "Web application" OAuth Client ID in Google Cloud Console and
# add http://localhost:5173 as an authorized JavaScript origin.
GOOGLE_SIGNIN_CLIENT_ID=

# WebAuthn / passkey (platform authenticator / fingerprint unlock) — local dev only for now.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=InvestIQ
WEBAUTHN_ORIGIN=http://localhost:5173

# Deprecated – kept for backward compatibility only (not used as primary)
NSE_BSE_MCP_ENABLED=false
NSE_BSE_MCP_URL=http://localhost:3000/mcp
NSE_BSE_MCP_READ_ONLY=true
NSE_BSE_MCP_TIMEOUT_SECONDS=20

# Kite MCP – read-only market data & portfolio (no order placement via InvestIQ)
KITE_MCP_ENABLED=true
KITE_MCP_URL=https://mcp.kite.trade/mcp
KITE_MCP_READ_ONLY=true
KITE_EXCLUDED_TOOLS=place_order,modify_order,cancel_order,place_gtt_order,modify_gtt_order,delete_gtt_order
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://127.0.0.1:8002/api/v1/kite/callback
KITE_FRONTEND_REDIRECT_URL=http://localhost:5173/portfolio

# Optional future provider
FMP_API_KEY=

# Search
TAVILY_API_KEY=

# Database & storage
SUPABASE_URL=
SUPABASE_ANON_KEY=
CHROMA_ENABLED=true
CHROMA_PERSIST_DIRECTORY=./chroma_data
CHROMA_COLLECTION_NAME=research_reports
STORAGE_ENABLED=true

# Logging & cache
LOG_LEVEL=INFO
# Set true to enable in-process TTL cache (search 10m, financial/history/chat 5m, status/report/holdings 60s)
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# CrewAI
CREW_VERBOSE=false
CREW_MEMORY=false

# Limits
MAX_NEWS_RESULTS=10
MAX_DOCUMENT_CHUNKS=20
MAX_SEARCH_RESULTS=10
